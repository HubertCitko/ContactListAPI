@page "/addContact"
@inject HttpClient Http
@using Blazored.LocalStorage
@inject ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<h3>Dodaj nowy kontakt</h3>
@if (errorMessages.Any())
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Uwaga! Popraw poniższe błędy:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var error in errorMessages)
            {
                <li>@error</li>
            }
        </ul>
        <button type="button" class="btn-close" @onclick="() => errorMessages.Clear()" aria-label="Close"></button>
    </div>
}
@if (isLoggedIn)
{
    <div class="card p-4 shadow-sm">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Imię</label>
                <input class="form-control" @bind="newContact.Name" />
            </div>
            <div class="col-md-6 mb-3">
                <label>Nazwisko</label>
                <input class="form-control" @bind="newContact.Surname" />
            </div>
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input type="email" class="form-control" @bind="newContact.Email" />
        </div>

        <div class="mb-3">
            <label>Hasło</label>
            <input class="form-control" @bind="newContact.Password" />
        </div>

        <div class="mb-3">
            <label>Telefon</label>
            <input type="tel" class="form-control" @bind="newContact.Phone" />
        </div>

        <div class="mb-3">
            <label>Data urodzenia</label>
            <input type="date" class="form-control" @bind="newContact.BirthDate" />
        </div>

        <div class="mb-3">
            <label>Kategoria</label>
            <select class="form-control" @onchange="OnCategoryChanged">
                <option value="">-- Wybierz kategorię --</option>
                <option value="1">Służbowy</option>
                <option value="2">Prywatny</option>
                <option value="3">Inny</option>
            </select>
        </div>

        @if (newContact.CategoryID == 1) // Służbowy
        {
            <div class="mb-3">
                <label>Podkategoria</label>
                <select class="form-control" @bind="newContact.SubcategoryID">
                    <option value="">-- Wybierz --</option>
                    <option value="1">Szef</option>
                    <option value="2">Klient</option>
                    <option value="3">Współpracownik</option>
                </select>
            </div>
        }
        else if (newContact.CategoryID == 3) // Inny
        {
            <div class="mb-3">
                <label>Wpisz własną podkategorię</label>
                <input class="form-control" @bind="newContact.OwnSubcategory" />
            </div>
        }

        <button class="btn btn-success mt-3" @onclick="SaveContact">Zapisz kontakt</button>
    </div>
}
else
{

        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Błąd!</strong> Opcja tylko dla zalogowanych urzytkowników
        </div>
    
}

@code {
    private ContactFormModel newContact = new();
    private List<string> errorMessages = new();

    [CascadingParameter]
    public bool isLoggedIn { get; set; }


    private void OnCategoryChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            newContact.CategoryID = id;
            newContact.SubcategoryID = null;
            newContact.OwnSubcategory = null;
        }
    }

    public class ValidationProblemDetails
    {
        public Dictionary<string, List<string>> Errors { get; set; } = new();
    }

    private async Task SaveContact()
    {
        errorMessages.Clear();

        var token = await LocalStorage.GetItemAsync<string>("authToken");
        Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var request = new HttpRequestMessage(HttpMethod.Post, "api/contact");
        request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        request.Content = JsonContent.Create(newContact);

        var response = await Http.SendAsync(request);

        if (response.IsSuccessStatusCode)
            NavigationManager.NavigateTo("/");
        else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            var problemDetails = await response.Content.ReadFromJsonAsync<ValidationProblemDetails>();

            if (problemDetails != null && problemDetails.Errors.Any())
            {
                foreach (var errorList in problemDetails.Errors.Values)
                {
                    errorMessages.AddRange(errorList);
                }
            }
            else
            {
                errorMessages.Add("Sprawdź poprawność wprowadzonych danych.");
            }
        }
        else
        {
            errorMessages.Add("Wystąpił problem z połączeniem z serwerem.");
        }
    }

    public class ContactFormModel
    {
        public string Name { get; set; } = "";
        public string Surname { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string Phone { get; set; } = "";
        public DateTime BirthDate { get; set; } = DateTime.Now;
        public int CategoryID { get; set; }
        public int? SubcategoryID { get; set; }
        public string? OwnSubcategory { get; set; }
    }
}